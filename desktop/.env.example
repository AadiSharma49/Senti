# ============================================================
# Senti desktop — build-time config.
#
# Copy to `.env`. This holds NO secrets: just where the app talks to.
# (All real keys live server-side in dashboard/.env — the desktop never
# sees them.)
#
#   cp .env.example .env
# ============================================================

# The Senti backend this build ships pointing at.
#
# Leave BLANK for local development (falls back to http://localhost:3000).
#
# Set it to your deployed dashboard before building an installer that other
# people will run — otherwise their copy tries to reach THEIR localhost and
# finds nothing:
#
#   VITE_SENTI_API_URL=https://your-senti.vercel.app
#   npm run dist
#
# A user can still override it in the app: Settings -> "Senti server".
VITE_SENTI_API_URL=
