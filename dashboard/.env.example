# Senti dashboard environment
#
# Copy this file to `.env.local` and fill in your Clerk keys to enable
# real authentication. Without these, the dashboard runs with the local
# demo sign-in flow.
#
# Get keys at https://dashboard.clerk.com → your app → API keys.

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Where Clerk sends users for auth (these match Senti's routes).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- AI assistant brain (optional, provider-swappable) ---
# Senti's greeting + conversational assistant. Set ONE of these. The router
# (lib/llm.ts) picks whichever is present; switching brains is just an env swap.
#
# Groq — free, fast Llama 3.3 70B, no credit card. Get a key at
# https://console.groq.com/keys
GROQ_API_KEY=
#
# Other OpenAI-compatible options (pick one instead of Groq if you prefer):
# XAI_API_KEY=xai-...            # xAI Grok (live X knowledge, paid)
# OPENAI_API_KEY=sk-...          # OpenAI GPT (paid)
# LLM_API_KEY=...                # any custom OpenAI-compatible endpoint...
# LLM_BASE_URL=https://.../v1    # ...paired with its base URL
# LLM_MODEL=                     # override the model for any of the above
#
# Google Gemini — free tier + built-in web search. Get a key at
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# --- Human voice (optional) ---
# ElevenLabs API key so replies are spoken in a real human voice (multilingual).
# The key MUST have the "text_to_speech" permission. Without a working key the
# desktop falls back to the browser's built-in voice.
# Get one at https://elevenlabs.io → Profile → API key.
ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB   # optional: pick a voice

# --- Database (Neon Postgres) ---
# Create a free Postgres DB at https://neon.tech, copy the connection
# string (use the pooled connection). Then run:
#   npx prisma migrate dev --name init
DATABASE_URL=postgresql://user:password@host/db?sslmode=require
