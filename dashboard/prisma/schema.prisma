// Senti platform data model.
// The dashboard owns this data; devices are secure endpoints that read it.
//
// Postgres (Neon). The same database serves local dev and the deployed
// dashboard, so a device sees identical data either way. DATABASE_URL lives
// in .env — the single env file both Next.js and the Prisma CLI read.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Runtime: Neon's POOLED endpoint (PgBouncer). Needs ?pgbouncer=true, or
  // Prisma's prepared statements break the pooler and connections get dropped
  // ("Error in PostgreSQL connection: kind: Closed").
  url = env("DATABASE_URL")
  // Migrations: a DIRECT connection. DDL cannot run through the pooler.
  directUrl = env("DIRECT_URL")
}

/// One row per account. `id` is the Clerk user id.
model User {
  id        String   @id
  email     String?  @unique
  name      String?
  createdAt DateTime @default(now())

  policy       Policy?
  voiceProfile VoiceProfile?
  devices      Device[]
  events       UnlockEvent[]
}

/// The account's enrolled voiceprint (captured on a device, synced up so
/// it flows to the user's other devices).
///
/// `embedding` is biometric data — the one credential a user can never
/// rotate — so it is stored ENCRYPTED (AES-256-GCM, see lib/crypto.ts),
/// not as a readable JSON array.
model VoiceProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  embedding   String
  sampleCount Int      @default(0)
  modelId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// The account security policy the devices obey. Unlock is voice-only:
/// the user says anything and the voiceprint decides. No wake phrase.
model Policy {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  voiceThreshold  Float    @default(0.5)
  maxAttempts     Int      @default(3)
  lockoutDuration Int      @default(30)
  updatedAt       DateTime @updatedAt
}

/// A computer running Senti under this account.
/// status: "online" | "locked" | "offline"
model Device {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  os            String
  status        String   @default("offline")
  voiceEnrolled Boolean  @default(false)
  /// SHA-256 of the device token. The raw token is shown once, at pairing,
  /// and never stored — a database leak yields no usable credentials.
  tokenHash     String   @unique
  linked        Boolean  @default(false)
  lastSeen      DateTime @default(now())
  createdAt     DateTime @default(now())

  /// Live status the desktop pushes so you can check it from your phone.
  /// activity: what Senti is doing now ("Idle", "Cleaning temp files", …)
  activity      String?
  /// A compact vitals line (RAM/disk), and when it was last reported.
  vitals        String?
  reportedAt    DateTime?

  events UnlockEvent[]
}

/// Security timeline entry.
/// type: "voice_unlock" | "pin_unlock" | "voice_rejected" | "lockout" | "enrolled"
model UnlockEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId  String?
  device    Device?  @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  type      String
  detail    String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}
