# ============================================================
# Senti — environment template.
#
# There is only ONE env file. Next.js and the Prisma CLI both read
# `.env`, so everything lives there — no .env.local, no split config.
#
#   cp .env.example .env      then fill in the real values
#
# `.env` is git-ignored. Never put real keys in THIS file.
# ============================================================

# --- Database (Neon Postgres) -------------------------------
# Free Postgres at https://neon.tech → create a project → copy the
# POOLED connection string. Then create the tables:
#   npm run db:migrate
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# --- Auth (Clerk) -------------------------------------------
# https://dashboard.clerk.com → your app → API keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- Assistant brain (set ONE) ------------------------------
# The router in lib/llm.ts uses whichever key is present, so you can
# swap providers with no code change.
#
# Groq — free, fast Llama 3.3 70B, no credit card.
#   https://console.groq.com/keys
GROQ_API_KEY=
# XAI_API_KEY=          # xAI Grok (live X knowledge, paid)
# OPENAI_API_KEY=       # OpenAI GPT (paid)
# GEMINI_API_KEY=       # Google Gemini (adds live web search)
# LLM_API_KEY=          # any custom OpenAI-compatible endpoint...
# LLM_BASE_URL=         # ...paired with its base URL
# LLM_MODEL=            # override the model for any of the above

# --- Encryption (REQUIRED in production) --------------------
# Voiceprints are biometric data — the one credential a user can never
# rotate — so they are encrypted at rest with AES-256-GCM using this key.
# Without it, they would be stored readable. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# LOSING THIS KEY MEANS LOSING EVERY ENROLLED VOICEPRINT (users re-enroll).
# Set the SAME value in Vercel, or the deployed app cannot read what local
# dev wrote.
SENTI_ENCRYPTION_KEY=

# --- Voice (ElevenLabs, optional) ---------------------------
# The key MUST have the "text_to_speech" permission. Voice Library
# voices need a PAID plan; these premade ones are free:
#   Brian nPczCjzI2devNBz1zQrb (natural, default)
#   Chris iP95p4xoKVk53GoZ742B | Will bIHbv24MWmeRgasZH58o
#   Eric  cjVigY5qzO86Huf0OWal | Adam pNInz6obpgDQGcFmaJgB (deep)
# Without a working key, the desktop falls back to the browser voice.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=nPczCjzI2devNBz1zQrb
# ELEVENLABS_MODEL=eleven_turbo_v2_5
