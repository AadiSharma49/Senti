{
  "name": "senti",
  "version": "0.1.0",
  "description": "Senti — AI-powered desktop guardian and assistant",
  "author": "Senti",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder --dir",
    "preview": "vite preview",
    "electron:dev": "npm run dev",
    "dist": "tsc && vite build && electron-builder --win nsis",
    "electron:build": "vite build && electron-builder",
    "setup:voice": "node scripts/setup-voice-model.mjs",
    "make:icon": "node scripts/make-icon.mjs"
  },
  "build": {
    "appId": "com.senti.desktop",
    "productName": "Senti",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist-electron/**/*",
      "dist/**/*",
      "!**/*.map"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Senti",
      "artifactName": "Senti-Setup.exe",
      "uninstallDisplayName": "Senti"
    }
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "framer-motion": "^11.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.2.0"
  }
}
