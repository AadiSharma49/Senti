{
  "name": "senti",
  "version": "0.1.0",
  "description": "Senti — AI-powered desktop guardian and assistant",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
